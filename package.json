{
    "name": "codebinx",
    "private": true,
    "version": "1.0.0",
    "description": "CodeBinX | Share code privately & easily - Fullstack Application",
    "workspaces": [
        "frontend",
        "backend",
        "shared"
    ],
    "engines": {
        "npm": "please-use-pnpm",
        "pnpm":">=8.0.0"
    },
    "scripts": {
        "dev:frontend": "pnpm --filter codebinx-frontend dev",
        "dev:backend": "pnpm --filter codebinx-backend dev",
        "build:frontend": "pnpm --filter codebinx-frontend build",
        "build:backend": "pnpm --filter codebinx-backend build",
        "build:shared": "pnpm --filter shared build",
        "build:all": "pnpm build:shared && pnpm build:backend && pnpm build:frontend",
        "start:backend": "pnpm --filter codebinx-backend start",
        "dev": "concurrently -n FRONTEND,BACKEND -c blue,green \"pnpm dev:frontend\" \"pnpm dev:backend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "typescript": "^5.x.x" 
    }
}