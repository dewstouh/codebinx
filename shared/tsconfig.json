{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "declaration": true,
        "declarationMap": true, 
        "sourceMap": true,
        "composite": true,
        "outDir": "./dist",
        "rootDir": "./src", 
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true, 
        "moduleResolution": "node"
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}