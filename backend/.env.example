NODE_ENV="development"
PORT="3000"

# Database
MONGODB_URI="mongodb+srv://<name>:<password>@cluster0.<clusterId>.mongodb.net/<databaseName>"

# JWT
JWT_SECRET="superlongjwtsecrethere"
JWT_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID="yoursupersecretgoogleclientid"
GOOGLE_CLIENT_SECRET="yoursupersecretclientsecret"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Bin Configuration
MAX_BIN_SIZE="1048576"
DEFAULT_BIN_EXPIRY_DAYS="30"