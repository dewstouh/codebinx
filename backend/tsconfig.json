{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true, // Puede ser útil
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "composite": true,
        "baseUrl": "./src",
        "paths": {
            "@/*": [
                "*"
            ],
            "@codebinx/shared": [
                "../shared/src"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts"
    ],
    "references": [
        {
            "path": "../shared"
        }
    ]
}